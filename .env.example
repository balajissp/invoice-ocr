POSTGRES_USER=postgres                # PostgreSQL username
POSTGRES_PASSWORD=s2labs              # PostgreSQL password
POSTGRES_DB=invoice_db                # Database name
POSTGRES_HOST=db                      # PostgreSQL host (use 'db' in Docker, 'localhost' locally)
POSTGRES_PORT=5432                    # PostgreSQL port
POSTGRES_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

TMP_DIR=D:\s2labs\.temp\              # OS directory for temporary files

FASTAPI_PORT=8000                     # FastAPI server port
FASTAPI_HOST=0.0.0.0                  # FastAPI server host

OPENAI_API_KEY=sk-...

LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com  # or your region
